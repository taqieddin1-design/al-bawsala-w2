rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['completedSections', 'updatedAt']) 
        && data.keys().size() == 2
        && data.completedSections is list 
        && data.completedSections.size() <= 100
        && data.updatedAt == request.time;
    }

    match /progress/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId
                    && isValidUserProgress(incoming());
      allow update: if isSignedIn() && request.auth.uid == userId
                    && isValidUserProgress(incoming());
    }

    function isValidComment(data) {
      return data.keys().hasAll(['text', 'userId', 'userName', 'createdAt'])
        && data.keys().size() == 4
        && data.text is string && data.text.size() > 0 && data.text.size() <= 1000
        && data.userId is string && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 100
        && data.createdAt == request.time;
    }

    match /comments/{commentId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidComment(incoming());
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
